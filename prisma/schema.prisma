generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  portfolio Portfolio?
  orders    Order[]
  trades    Trade[]
}

model Portfolio {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id])
  userId         String    @unique
  cashBalance    Float     @default(100000)
  totalValue     Float     @default(100000)
  initialBalance Float     @default(100000)
  createdAt      DateTime  @default(now())
  holdings       Holding[]
  orders         Order[]
}

model Holding {
  id          String    @id @default(uuid())
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  portfolioId String
  symbol      String
  quantity    Float
  avgCost     Float
  updatedAt   DateTime  @updatedAt

  @@unique([portfolioId, symbol])
}

model Order {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  portfolioId String
  symbol      String
  type        String
  side        String
  quantity    Float
  price       Float?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  filledAt    DateTime?
  trades      Trade[]

  @@index([userId, status])
  @@index([symbol, type, status])
}

model Trade {
  id         String   @id @default(uuid())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  symbol     String
  side       String
  quantity   Float
  price      Float
  totalValue Float
  fee        Float    @default(0)
  executedAt DateTime @default(now())

  @@index([userId, executedAt])
}
